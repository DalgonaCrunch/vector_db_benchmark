# Upstage API
UPSTAGE_API_KEY=your_upstage_api_key_here
UPSTAGE_API_URL=https://api.upstage.ai/v1/embeddings
UPSTAGE_PASSAGE_MODEL=embedding-passage
UPSTAGE_QUERY_MODEL=embedding-query
EMBEDDING_BATCH_SIZE=32

# OpenSearch
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_INDEX=benchmark_index
# lucene: pure-Java, works on WSL. nmslib/faiss require native libs (crash on WSL)
OPENSEARCH_KNN_ENGINE=lucene
OPENSEARCH_SPACE_TYPE=cosinesimil
OPENSEARCH_EF_CONSTRUCTION=128
OPENSEARCH_M=16

# Qdrant
# QDRANT_MODE options:
#   memory  → in-process, no server needed (fastest setup)
#   local   → persistent on-disk via QDRANT_LOCAL_PATH, no server needed
#   server  → connect to a running Qdrant server at QDRANT_HOST:QDRANT_PORT
QDRANT_MODE=local
QDRANT_LOCAL_PATH=./qdrant_data
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=benchmark_collection

# Ingestion (PDF → Chunks)
PDF_DIR=./data/pdfs
CHUNK_SIZE_TOKENS=650
CHUNK_OVERLAP_TOKENS=100

# Benchmark
TOP_K=5
NUM_REPEATS=20
OUTPUT_CSV=benchmark_results.csv

# LLM Providers (for RAG Chatbot - set whichever you use)
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
